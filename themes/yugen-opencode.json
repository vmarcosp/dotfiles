{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "color100": "#FAFAFA",
    "color200": "#D4D4D4",
    "color300": "#A9A9A9",
    "color400": "#696969",
    "color500": "#505050",
    "color600": "#303030",
    "color700": "#151515",
    "color800": "#000000",
    "primary": "#FFBE89",
    "success": "#7EAB8E",
    "warning": "#FFF2AF",
    "error": "#F57A7A",
    "red": "#F57A7A",
    "green": "#7EAB8E",
    "yellow": "#FFF2AF",
    "blue": "#8C9EB5",
    "magenta": "#FFBE89",
    "cyan": "#5FAFAF",
    "white": "#DEDEDE"
  },
  "theme": {
    "primary": { "dark": "primary", "light": "primary" },
    "secondary": { "dark": "color300", "light": "color500" },
    "accent": { "dark": "warning", "light": "warning" },
    "error": { "dark": "error", "light": "error" },
    "warning": { "dark": "warning", "light": "warning" },
    "success": { "dark": "success", "light": "success" },
    "info": { "dark": "primary", "light": "primary" },
    "text": { "dark": "color200", "light": "color800" },
    "textMuted": { "dark": "color400", "light": "color500" },
    "background": { "dark": "color800", "light": "color100" },
    "backgroundPanel": { "dark": "color700", "light": "color200" },
    "backgroundElement": { "dark": "color600", "light": "color300" },
    "border": { "dark": "color600", "light": "color300" },
    "borderActive": { "dark": "color500", "light": "color400" },
    "borderSubtle": { "dark": "color700", "light": "color200" },
    "diffAdded": { "dark": "success", "light": "success" },
    "diffRemoved": { "dark": "error", "light": "error" },
    "diffContext": { "dark": "color400", "light": "color500" },
    "diffHunkHeader": { "dark": "color600", "light": "color300" },
    "diffHighlightAdded": { "dark": "success", "light": "success" },
    "diffHighlightRemoved": { "dark": "error", "light": "error" },
    "diffAddedBg": { "dark": "#1a2a1f", "light": "#d4edda" },
    "diffRemovedBg": { "dark": "#2a1a1a", "light": "#f8d7da" },
    "diffContextBg": { "dark": "color700", "light": "color200" },
    "diffLineNumber": { "dark": "color500", "light": "color400" },
    "diffAddedLineNumberBg": { "dark": "#1a2a1f", "light": "#d4edda" },
    "diffRemovedLineNumberBg": { "dark": "#2a1a1a", "light": "#f8d7da" },
    "markdownText": { "dark": "color200", "light": "color800" },
    "markdownHeading": { "dark": "primary", "light": "primary" },
    "markdownLink": { "dark": "blue", "light": "blue" },
    "markdownLinkText": { "dark": "primary", "light": "primary" },
    "markdownCode": { "dark": "success", "light": "success" },
    "markdownBlockQuote": { "dark": "color400", "light": "color500" },
    "markdownEmph": { "dark": "warning", "light": "warning" },
    "markdownStrong": { "dark": "primary", "light": "primary" },
    "markdownHorizontalRule": { "dark": "color600", "light": "color300" },
    "markdownListItem": { "dark": "primary", "light": "primary" },
    "markdownListEnumeration": { "dark": "primary", "light": "primary" },
    "markdownImage": { "dark": "blue", "light": "blue" },
    "markdownImageText": { "dark": "primary", "light": "primary" },
    "markdownCodeBlock": { "dark": "color200", "light": "color800" },
    "syntaxComment": { "dark": "color400", "light": "color500" },
    "syntaxKeyword": { "dark": "red", "light": "red" },
    "syntaxFunction": { "dark": "primary", "light": "primary" },
    "syntaxVariable": { "dark": "color200", "light": "color800" },
    "syntaxString": { "dark": "success", "light": "success" },
    "syntaxNumber": { "dark": "warning", "light": "warning" },
    "syntaxType": { "dark": "cyan", "light": "cyan" },
    "syntaxOperator": { "dark": "blue", "light": "blue" },
    "syntaxPunctuation": { "dark": "color300", "light": "color600" }
  }
}
